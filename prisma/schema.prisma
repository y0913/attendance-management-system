// 勤怠管理システム
// 仕様: ../CLAUDE.md
// 規約: ../.claude/SKILL/prisma-migration-discipline/SKILL.md

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// =============================================================================
// Enums
// =============================================================================

enum Role {
  admin
  approver
  general
}

enum EmploymentType {
  monthly
  hourly
}

enum MidMonthRateChangeStrategy {
  daily
  month_end
}

enum TimeClockType {
  clock_in
  clock_out
  break_start
  break_end
}

enum TimeClockSource {
  web
  manual_correction
}

enum DailyAttendanceStatus {
  resolved
  missing_clock_out
  missing_clock_in
  no_record
}

enum RequestStatus {
  draft
  submitted
  approved
  rejected
  withdrawn
  returned
}

enum ApprovalActionType {
  submit
  approve
  reject
  withdraw
  return
}

enum ApprovalRequestType {
  clock_correction
  leave_request
}

enum LeaveType {
  annual
}

enum LeaveGrantSource {
  legal_auto
  manual
}

// =============================================================================
// Domain models
// =============================================================================

model Company {
  id                         String                     @id @default(cuid())
  name                       String
  closingDay                 Int                        @default(0) @map("closing_day")
  midMonthRateChangeStrategy MidMonthRateChangeStrategy @default(month_end) @map("mid_month_rate_change_strategy")
  createdAt                  DateTime                   @default(now()) @map("created_at")
  updatedAt                  DateTime                   @updatedAt @map("updated_at")

  users              User[]
  workRuleVersions   WorkRuleVersion[]
  attendanceClosings AttendanceClosing[]

  @@map("companies")
}

model User {
  id             String         @id @default(cuid())
  // Auth.js standard fields
  name           String?
  email          String         @unique
  emailVerified  DateTime?      @map("email_verified")
  image          String?
  // App fields
  companyId      String         @map("company_id")
  role           Role           @default(general)
  managerId      String?        @map("manager_id")
  employmentType EmploymentType @default(monthly) @map("employment_type")
  hiredAt        DateTime?      @map("hired_at") @db.Date
  baseSalary     Int?           @map("base_salary")
  deactivatedAt  DateTime?      @map("deactivated_at")
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")

  company Company @relation(fields: [companyId], references: [id])
  manager User?   @relation("ManagerToReports", fields: [managerId], references: [id])
  reports User[]  @relation("ManagerToReports")

  accounts Account[]
  sessions Session[]

  timeClocks              TimeClock[]
  dailyAttendances        DailyAttendance[]
  clockCorrectionRequests ClockCorrectionRequest[] @relation("ClockCorrectionRequester")
  pendingClockCorrections ClockCorrectionRequest[] @relation("ClockCorrectionApprover")
  leaveRequests           LeaveRequest[]           @relation("LeaveRequester")
  pendingLeaveRequests    LeaveRequest[]           @relation("LeaveRequestApprover")
  approvalActions         ApprovalAction[]
  leaveGrants             LeaveGrant[]
  attendanceClosings      AttendanceClosing[]      @relation("ClosingSubject")
  closingsClosed          AttendanceClosing[]      @relation("ClosedBy")
  workRuleVersionsCreated WorkRuleVersion[]        @relation("WorkRuleVersionCreator")
  auditLogsActed          AuditLog[]               @relation("AuditLogActor")

  @@index([companyId])
  @@index([managerId])
  @@map("users")
}

model WorkRuleVersion {
  id                     String   @id @default(cuid())
  companyId              String   @map("company_id")
  validFrom              DateTime @map("valid_from")
  dailyOtThresholdMin    Int      @default(480) @map("daily_ot_threshold_min")
  weeklyOtThresholdMin   Int      @default(2400) @map("weekly_ot_threshold_min")
  otRate                 Decimal  @default(1.25) @map("ot_rate") @db.Decimal(5, 4)
  nightStartTime         String   @default("22:00") @map("night_start_time")
  nightEndTime           String   @default("05:00") @map("night_end_time")
  nightRateAddition      Decimal  @default(0.25) @map("night_rate_addition") @db.Decimal(5, 4)
  legalHolidayRate       Decimal  @default(1.35) @map("legal_holiday_rate") @db.Decimal(5, 4)
  monthly60hOtRate       Decimal  @default(1.5) @map("monthly_60h_ot_rate") @db.Decimal(5, 4)
  monthly60hThresholdMin Int      @default(3600) @map("monthly_60h_threshold_min")
  complianceMode         Boolean  @default(true) @map("compliance_mode")
  createdAt              DateTime @default(now()) @map("created_at")
  createdById            String   @map("created_by")

  company   Company @relation(fields: [companyId], references: [id])
  createdBy User    @relation("WorkRuleVersionCreator", fields: [createdById], references: [id])

  @@unique([companyId, validFrom])
  @@index([companyId, validFrom])
  @@map("work_rule_versions")
}

model TimeClock {
  id         String          @id @default(cuid())
  userId     String          @map("user_id")
  occurredAt DateTime        @map("occurred_at")
  type       TimeClockType
  source     TimeClockSource @default(web)
  createdAt  DateTime        @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@index([userId, occurredAt])
  @@map("time_clocks")
}

model DailyAttendance {
  id               String                @id @default(cuid())
  userId           String                @map("user_id")
  workDate         DateTime              @map("work_date") @db.Date
  status           DailyAttendanceStatus
  clockInAt        DateTime?             @map("clock_in_at")
  clockOutAt       DateTime?             @map("clock_out_at")
  breakMinutes     Int?                  @map("break_minutes")
  workMinutes      Int?                  @map("work_minutes")
  otMinutes        Int?                  @map("ot_minutes")
  nightMinutes     Int?                  @map("night_minutes")
  otNightMinutes   Int?                  @map("ot_night_minutes")
  legalHolidayFlag Boolean               @default(false) @map("legal_holiday_flag")
  recalculatedAt   DateTime              @default(now()) @map("recalculated_at")

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, workDate])
  @@index([userId, workDate])
  @@map("daily_attendances")
}

model ClockCorrectionRequest {
  id                String        @id @default(cuid())
  requesterId       String        @map("requester_id")
  status            RequestStatus @default(draft)
  currentApproverId String?       @map("current_approver_id")
  submittedAt       DateTime?     @map("submitted_at")
  reason            String
  targetDate        DateTime      @map("target_date") @db.Date
  beforePayload     Json          @map("before_payload")
  afterPayload      Json          @map("after_payload")
  createdAt         DateTime      @default(now()) @map("created_at")
  updatedAt         DateTime      @updatedAt @map("updated_at")

  requester       User  @relation("ClockCorrectionRequester", fields: [requesterId], references: [id])
  currentApprover User? @relation("ClockCorrectionApprover", fields: [currentApproverId], references: [id])

  @@index([requesterId, status])
  @@index([currentApproverId, status])
  @@map("clock_correction_requests")
}

model LeaveRequest {
  id                String        @id @default(cuid())
  requesterId       String        @map("requester_id")
  status            RequestStatus @default(draft)
  currentApproverId String?       @map("current_approver_id")
  submittedAt       DateTime?     @map("submitted_at")
  reason            String
  leaveType         LeaveType     @default(annual) @map("leave_type")
  startDate         DateTime      @map("start_date") @db.Date
  endDate           DateTime      @map("end_date") @db.Date
  days              Decimal       @db.Decimal(4, 1)
  createdAt         DateTime      @default(now()) @map("created_at")
  updatedAt         DateTime      @updatedAt @map("updated_at")

  requester       User  @relation("LeaveRequester", fields: [requesterId], references: [id])
  currentApprover User? @relation("LeaveRequestApprover", fields: [currentApproverId], references: [id])

  @@index([requesterId, status])
  @@index([currentApproverId, status])
  @@map("leave_requests")
}

// 注意: polymorphic-lite。requestType + requestId で参照先を識別する。
// Prisma リレーションは張らず、アプリ層で resolve する。
model ApprovalAction {
  id          String              @id @default(cuid())
  requestType ApprovalRequestType @map("request_type")
  requestId   String              @map("request_id")
  actorId     String              @map("actor_id")
  action      ApprovalActionType
  comment     String?
  createdAt   DateTime            @default(now()) @map("created_at")

  actor User @relation(fields: [actorId], references: [id])

  @@index([requestType, requestId])
  @@index([actorId, createdAt])
  @@map("approval_actions")
}

model LeaveGrant {
  id          String           @id @default(cuid())
  userId      String           @map("user_id")
  grantedAt   DateTime         @map("granted_at") @db.Date
  expiresAt   DateTime         @map("expires_at") @db.Date
  grantedDays Decimal          @map("granted_days") @db.Decimal(4, 1)
  usedDays    Decimal          @default(0) @map("used_days") @db.Decimal(4, 1)
  source      LeaveGrantSource
  createdAt   DateTime         @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@index([userId, expiresAt])
  @@map("leave_grants")
}

model AttendanceClosing {
  id         String   @id @default(cuid())
  companyId  String   @map("company_id")
  userId     String   @map("user_id")
  yearMonth  String   @map("year_month")
  closedAt   DateTime @default(now()) @map("closed_at")
  closedById String   @map("closed_by")
  snapshot   Json

  company  Company @relation(fields: [companyId], references: [id])
  user     User    @relation("ClosingSubject", fields: [userId], references: [id])
  closedBy User    @relation("ClosedBy", fields: [closedById], references: [id])

  @@unique([userId, yearMonth])
  @@index([companyId, yearMonth])
  @@map("attendance_closings")
}

model AuditLog {
  id         String   @id @default(cuid())
  entityType String   @map("entity_type")
  entityId   String   @map("entity_id")
  action     String
  actorId    String   @map("actor_id")
  before     Json?
  after      Json?
  createdAt  DateTime @default(now()) @map("created_at")

  actor User @relation("AuditLogActor", fields: [actorId], references: [id])

  @@index([entityType, entityId])
  @@index([actorId, createdAt])
  @@map("audit_logs")
}

// =============================================================================
// Auth.js (NextAuth) adapter models
// =============================================================================

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}
